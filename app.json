{
  "expo": {
    "name": "CheckYourself",
    "slug": "checkYourselfRN",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "check-yourself-login",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4e6d2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kiera.checkyourself",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["spotify"]
      }
    },
    "android": {
      "package": "com.kiera.checkyourself",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/web-favicon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
